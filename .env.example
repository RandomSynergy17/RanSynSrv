################################################################################
# RanSynSrv Configuration
################################################################################
# Copy: cp .env.example .env
# Edit: nano .env
################################################################################

# ==============================================================================
# COMPOSE PROJECT NAME (for multi-instance deployments)
# ==============================================================================
# Uncomment and set a unique name for each instance to avoid conflicts
# Also uncomment the 'networks' section in docker-compose.yml
# Examples:
#   COMPOSE_PROJECT_NAME=ransynsrv_prod
#   COMPOSE_PROJECT_NAME=ransynsrv_staging
#   COMPOSE_PROJECT_NAME=ransynsrv_v2
# Default: Uses folder name (e.g., "ransynsrv" → "ransynsrv_default" network)

# COMPOSE_PROJECT_NAME=ransynsrv

# ==============================================================================
# USER MAPPING (Required)
# ==============================================================================
# Run: id $USER → uid=1000(user) gid=1000(user)

PUID=1000
PGID=1000

# ==============================================================================
# TIMEZONE
# ==============================================================================

TZ=Asia/Dubai

# ==============================================================================
# NETWORK
# ==============================================================================

HTTP_PORT=8080

# ==============================================================================
# DATA STORAGE
# ==============================================================================
# Where web files, logs, and configs are stored

DATA_PATH=./data

# ==============================================================================
# PHP SETTINGS
# ==============================================================================

PHP_MEMORY_LIMIT=256M
PHP_MAX_UPLOAD=50M
PHP_MAX_POST=50M
PHP_MAX_EXECUTION_TIME=300

# ==============================================================================
# GOACCESS ANALYTICS
# ==============================================================================
# Real-time dashboard at /goaccess
# WebSocket URL for real-time updates
# IMPORTANT: Must match how you access the container
#
# Local development:
#   GOACCESS_WS_URL=ws://localhost:8080/goaccess/ws
#
# Production with SSL:
#   GOACCESS_WS_URL=wss://yourdomain.com/goaccess/ws
#
# Production without SSL:
#   GOACCESS_WS_URL=ws://yourdomain.com/goaccess/ws
#
# Leaving this empty prints a warning at boot and falls back to
# ws://localhost/goaccess/ws — fine for local-only but wrong behind a proxy.

GOACCESS_ENABLED=true
GOACCESS_WS_URL=ws://localhost:8080/goaccess/ws

# HTTP Basic Authentication (optional)
# Protects the /goaccess dashboard with username/password
GOACCESS_AUTH_ENABLED=false
GOACCESS_USERNAME=admin
GOACCESS_PASSWORD=

# ==============================================================================
# TTYD WEB TERMINAL
# ==============================================================================
# Web-based terminal access at /ttyd
# Disabled by default for security.
#
# ⚠️ WARNING: if TTYD_ENABLED=true and either TTYD_USERNAME or TTYD_PASSWORD
# is empty, ttyd will be reachable WITHOUT any authentication at the nginx
# layer. Init logs a loud warning at boot when this happens, but it won't
# refuse to start — so double-check both values before flipping ENABLED on.

TTYD_ENABLED=false
TTYD_USERNAME=admin
TTYD_PASSWORD=

# ==============================================================================
# CLAUDE CODE
# ==============================================================================
# Get your key: https://console.anthropic.com/
# Claude Code CLI is pinned via Dockerfile ARG CLAUDE_CODE_VERSION; bump there
# and rebuild to upgrade. Config stored in: ./data/claude/.claude.

ANTHROPIC_API_KEY=

# ==============================================================================
# RUNTIME PACKAGE INSTALL (universal-package-install mod)
# ==============================================================================
# Space-separated list of packages to install on startup
# Example: INSTALL_PACKAGES=mc tig
# Example: INSTALL_PIP_PACKAGES=pandas numpy

INSTALL_PACKAGES=
INSTALL_PIP_PACKAGES=

# ==============================================================================
# STDOUT LOGGING (universal-stdout-logs mod)
# ==============================================================================
# Set to true to send logs to Docker logging driver
# Useful for: docker compose logs -f
# Note: GoAccess real-time analytics requires DOCKER_LOGS=false — GoAccess
# tails /data/log/nginx/access.log directly and can't read stdout piped to PID 1.

DOCKER_LOGS=false

# ==============================================================================
# AI SIDECAR OVERLAY (docker-compose.ai.yml, optional)
# ==============================================================================
# Adds pgvector-enabled Postgres 17 + text-embeddings-inference serving
# BGE-small-en-v1.5. Enabled only when you include the overlay:
#   docker compose -f docker-compose.yml -f docker-compose.ai.yml up -d
#
# PHP apps inside ransynsrv reach the sidecars by service name:
#   postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
#   http://embedder/embed   (POST {"inputs":"..."} → JSON array of floats)

# --- Postgres ---
# POSTGRES_PASSWORD is required when the overlay is active; compose fails fast
# with a helpful error if unset. User and DB default to "ransynsrv".
POSTGRES_USER=ransynsrv
POSTGRES_PASSWORD=
POSTGRES_DB=ransynsrv
POSTGRES_HOST_PORT=5432
# POSTGRES_INITDB_ARGS=--data-checksums
# POSTGRES_MEM_LIMIT=1g

# --- Embedder (Text Embeddings Inference / HuggingFace) ---
# Swap model by changing EMBEDDER_MODEL; the TEI container downloads on first
# boot and caches under ${DATA_PATH}/tei-cache.
#
# Model memory guide (cache / RAM-when-loaded):
#   BAAI/bge-small-en-v1.5   ~130MB / ~500MB   384 dims  (default)
#   BAAI/bge-base-en-v1.5    ~440MB / ~1GB     768 dims
#   BAAI/bge-large-en-v1.5   ~1.3GB / ~2GB    1024 dims
#   BAAI/bge-m3              ~2.3GB / ~4GB    1024 dims  (multilingual)
#
# When changing EMBEDDER_MODEL:
#  - set EMBEDDER_MEM_LIMIT appropriately from the table above
#  - clean ${DATA_PATH}/tei-cache to reclaim the old model's weights
#  - recreate your pgvector columns with the NEW dimensionality (you cannot
#    INSERT a 768-dim vector into a 384-dim column)
EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
EMBEDDER_HOST_PORT=7997
# EMBEDDER_BIND_ADDR=0.0.0.0     # override 127.0.0.1 default to expose externally
# EMBEDDER_MEM_LIMIT=2g

# Auto-truncation: by default TEI silently clips inputs longer than the model's
# max sequence length. That's the right call for RAG embedding workloads. If
# you need HTTP 413 errors on over-length inputs instead (document-integrity
# workloads), override the `command:` in a compose override file or edit
# docker-compose.ai.yml and rebuild — it's not env-driven because Compose's
# `${VAR:-default}` interpolation can't cleanly express a conditional flag.
